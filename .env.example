# Payment Gateway — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to version control.

# Server
PORT=8080
APP_ENV=development    # "development" or "production"

# Database (Supabase PostgreSQL)
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# GCP Cloud KMS
# Format: projects/PROJECT_ID/locations/LOCATION/keyRings/KEY_RING/cryptoKeys/KEY_NAME
KMS_KEY_RESOURCE_NAME=projects/your-project/locations/us-central1/keyRings/payment-gateway/cryptoKeys/merchant-credentials

# BNC Bank API
# QA:   https://servicios.bncenlinea.com:16500/api
# Prod: https://servicios.bncenlinea.com:PORT/api (confirm port with BNC)
BNC_BASE_URL=https://servicios.bncenlinea.com:16500/api

# BNC Webhook Authentication
# Shared secret agreed during BNC onboarding. BNC sends this in x-api-key header.
# If empty, webhook accepts ALL requests (INSECURE — only for local dev without mock).
BNC_WEBHOOK_API_KEY=

# CORS — Allowed origin for dashboard requests
# Dev: http://localhost:3001 | Prod: https://dashboard.tudominio.com
CORS_ALLOWED_ORIGIN=http://localhost:3001
